# 复制本文件为 .env,填入 web 安全 key(⚠️ 别用 tp- 编程工具 key,有封号风险)。
# 填好后重启 dev(npm run dev / tauri dev),待估算项目的「AI 拟里程碑草稿」就从启发式升级为真 LLM。
# 注:当前只有 dev 版用 LLM;装在 /Applications 的正式 .app 用启发式(要 LLM 进 .app 需把调用 port 进 Rust)。

HUB_AI_KEY=sk-或ds-你的key

# 可选(默认走 DeepSeek):
# HUB_AI_BASE=https://api.deepseek.com/v1
# HUB_AI_MODEL=deepseek-chat
# Kimi 例:HUB_AI_BASE=https://api.moonshot.cn/v1  HUB_AI_MODEL=moonshot-v1-8k
